{
  "name": "agi-desktop",
  "private": true,
  "version": "0.1.7",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "vite build",
    "test": "tsc --noEmit",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "build:icons": "python3 ./scripts/generate_tauri_icons.py",
    "build:hostd": "bash ./scripts/build_hostd.sh",
    "tauri:dev": "npm run build:hostd && tauri dev",
    "tauri:build": "npm run build:hostd && tauri build",
    "tauri:build:linux": "bash ./scripts/build_linux_packages.sh"
  },
  "dependencies": {
    "@agi/frontend": "file:../../packages/frontend",
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.7.3",
    "vite": "^7.1.0"
  }
}
